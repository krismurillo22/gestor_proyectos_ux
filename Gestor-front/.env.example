# Copia este archivo a ".env" (mismo folder, sin ".example") y pon ahí la
# URL real del backend cuando exista. Mientras no exista, no hace falta
# crear el .env: el front sigue funcionando con datos mock.
#
# Ejemplo si el backend corre local en el puerto 3000:
VITE_API_BASE_URL=http://localhost:3000/api
